# API
HS_API_DATA_DIR=/var/lib/hs-data-api
HS_API_BIND_HOST=127.0.0.1
HS_API_PORT=8000
HS_API_KEY=change-me
HS_CORS_ALLOWED_ORIGINS=https://api.hs-manacost.ru
HS_API_REQUEST_DELAY_SECONDS=8.0
HS_API_REQUEST_TIMEOUT_SECONDS=150.0

# Refresh parallelism
HS_REFRESH_PARALLEL_LIGHT=3
HS_REFRESH_PARALLEL_MEDIUM=2
HS_REFRESH_PARALLEL_STAGGER_MIN=0.5
HS_REFRESH_PARALLEL_STAGGER_MAX=1.5
HS_REFRESH_DELAY_BROWSER_ONLY=true
HS_REFRESH_PREFLIGHT_STRICT=true
HS_REFRESH_PREFLIGHT_PROBE_HSREPLAY=true
HS_STALE_HOURS=12

# HSReplay channels
HS_HSREPLAY_JSON_CHANNELS=curl_cffi,flaresolverr
HS_HSREPLAY_MARKDOWN_CHANNELS=flaresolverr,curl_cffi
HS_API_JSON_ATTEMPTS_PER_CHANNEL=2
HS_API_JSON_RETRY_DELAY_SECONDS=2.0

# Observability and data integrity
HS_TELEGRAM_ALERT_DEDUP_SECONDS=3600
HS_LOG_ROTATE_MAX_BYTES=52428800
HS_LOG_ROTATE_MAX_AGE_DAYS=7
HS_DATASET_REGRESSION_DROP_RATIO=0.30

# Firecrawl fallback/updaters
# Prefer a rotated key here; never commit real Firecrawl keys to git.
FIRECRAWL_API_KEY=
HS_FIRECRAWL_MAX_AGE_MS=172800000
HS_FIRECRAWL_WAIT_MS=5000
HS_FIRECRAWL_TIMEOUT_MS=30000
HS_FIRECRAWL_STREAMER_DECK_LIMIT=200
HS_FIRECRAWL_PRIMARY_SOURCE_IDS=hsguru_streamer_decks_legend_1000
HS_FIRECRAWL_FALLBACK_SOURCE_IDS=hsguru_meta_standard_legend,hsguru_meta_standard_diamond_4to1,hsguru_meta_wild_legend,hsguru_meta_wild_diamond_4to1,hsguru_meta_standard_top_5k,hsguru_meta_standard_top_legend,hsguru_meta_wild_top_legend,hsguru_meta_wild_top_5k,hsguru_matchups_legend,hsguru_matchups_diamond_4to1,hsreplay_battlegrounds_comps,hsreplay_battlegrounds_heroes,hsreplay_battlegrounds_trinkets_lesser,hsreplay_battlegrounds_trinkets_greater,hsreplay_decks_trending,heartharena_tierlist,vicious_syndicate_radars
HS_FIRECRAWL_FALLBACK_MAX_ATTEMPTS_PER_REFRESH=8

# Scraping proxy
HS_FETCH_REQUIRE_PROXY=true
HS_FETCH_DIRECT_ENABLED=false
HS_FETCH_PROXY_URL=http://USER:PASS@geo.iproyal.com:12321
HS_PROXY_STICKY_MODE=domain
HS_IPROYAL_SESSION_LIFETIME=30m
HS_HTTP_RETRY_ATTEMPTS=3
HS_PROXY_CHECK_URL=https://api.ipify.org

# Browser/backends
HS_FETCH_BACKENDS=flaresolverr,scrapling,patchright,curl_cffi,cloudscraper
HS_HSGURU_FETCH_BACKENDS=flaresolverr,scrapling,curl_cffi,cloudscraper,patchright
HS_FETCH_BACKENDS_LAB=cloakbrowser,flaresolverr,scrapling,patchright,curl_cffi,cloudscraper
HS_FETCH_MAX_RETRIES=3
HS_FETCH_BACKEND_MAX_SECONDS=240
HS_BROWSER_PREFERRED_STICKY_BACKENDS=flaresolverr,patchright,playwright
HS_FLARESOLVERR_URL=http://127.0.0.1:8191/v1
HS_FLARESOLVERR_SESSION_PER_SOURCE=true
HS_FLARESOLVERR_HSGURU_WAIT_MS=12000
HS_IPROYAL_SESSION_PER_SOURCE=false
HS_IPROYAL_ROTATE_PER_FETCH=false

# Experimental browser stack
HS_FINGERPRINT_SUITE_ENABLED=true
HS_CLOAKBROWSER_HUMANIZE=true
HS_CLOAKBROWSER_GEOIP=true
HS_CLOAKBROWSER_HEADLESS=false
HS_CLOAKBROWSER_HSGURU_HEADLESS=false
HS_CLOAKBROWSER_DISPLAY=:99
HS_SCRAPLING_SOLVE_CLOUDFLARE=true
HS_SCRAPLING_DISABLE_RESOURCES=true
HS_SCRAPLING_TIMEOUT_MS=180000

# HSReplay Premium (optional)
HSREPLAY_EMAIL=
HSREPLAY_PASSWORD=
HSREPLAY_STORAGE_PATH=/var/lib/hs-data-api/hsreplay-auth.json

# Telegram alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
