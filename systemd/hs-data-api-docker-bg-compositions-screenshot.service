[Unit]
Description=Capture HSReplay Battlegrounds compositions Firecrawl screenshot in Docker
Requires=hs-data-api-docker.service
After=hs-data-api-docker.service network-online.target

[Service]
Type=oneshot
WorkingDirectory=/srv/hs-data-api
ExecStart=/usr/bin/docker compose -f /srv/hs-data-api/docker-compose.yml run --rm api python -m app.cli capture-bg-compositions-screenshot
